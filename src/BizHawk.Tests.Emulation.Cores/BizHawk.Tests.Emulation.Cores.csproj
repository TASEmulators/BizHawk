<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<TargetFramework>net48</TargetFramework>
	</PropertyGroup>
	<Import Project="../MainSlnTest.props" />
	<ItemGroup>
		<ProjectReference Include="$(ProjectDir)../BizHawk.Emulation.Cores/BizHawk.Emulation.Cores.csproj" />
		<ProjectReference Include="$(ProjectDir)../BizHawk.Tests.Common/BizHawk.Tests.Common.csproj" />
	</ItemGroup>
	<!-- Optional external test-data (FUSE / ZEXALL). Copied to output if present; tests skip when absent. -->
	<ItemGroup>
		<None Include="Resources/**/*" CopyToOutputDirectory="PreserveNewest" Condition="Exists('Resources')" />
	</ItemGroup>
	<!-- Native DLLs the benchmarks need: floooh Z80 (native-vs-managed) + blip_buf (ZX beeper/whole-frame). -->
	<ItemGroup>
		<None Include="$(ProjectDir)../../Assets/dll/FlooohZ80.*" CopyToOutputDirectory="PreserveNewest" />
		<None Include="$(ProjectDir)../../Assets/dll/blip_buf.*" CopyToOutputDirectory="PreserveNewest" />
		<None Include="$(ProjectDir)../../Assets/dll/libblip_buf.*" CopyToOutputDirectory="PreserveNewest" />
	</ItemGroup>
</Project>
